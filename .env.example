# Dotty — self-hosted StackChan robot assistant
# Copy to .env and fill in real values before deploying.

# --- xiaozhi-esp32-server (docker-compose.yml) ---

# Container timezone (IANA format).
TZ=Australia/Brisbane

# --- zeroclaw-bridge (bridge.py) ---

# Path to the zeroclaw binary inside the bridge container or on bare metal.
ZEROCLAW_BIN=/root/.cargo/bin/zeroclaw

# FastAPI listen port for the bridge.
PORT=8080

# Seconds before a bridge -> ZeroClaw ACP call times out.
ZEROCLAW_TIMEOUT=90

# Seconds to wait for the ACP child to finish initializing.
ZEROCLAW_INIT_TIMEOUT=10

# Rotate the ACP session after this many seconds of inactivity.
ZEROCLAW_SESSION_IDLE=300

# Rotate the ACP session after this many conversational turns.
ZEROCLAW_SESSION_MAX_TURNS=50

# Rotate the ACP session after this many seconds of wall-clock age.
ZEROCLAW_SESSION_MAX_AGE_SEC=1800

# --- Debug flags ---

# Set to "1" to enable verbose streaming debug logs in the zeroclaw LLM provider.
# ZEROCLAW_STREAM_DEBUG=0
